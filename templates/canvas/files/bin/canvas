#!/usr/bin/env bash
# canvas — CLI for TLDraw bridge API
# Usage: canvas <command> [args...]

set -euo pipefail

BRIDGE="${CANVAS_BRIDGE_URL:-http://localhost:3100}"

# Helpers that show errors instead of silently failing
_post() {
  local resp
  resp=$(curl -s -w '\n%{http_code}' -X POST "$BRIDGE$1" -H 'Content-Type: application/json' -d "$2")
  local code body
  code=$(echo "$resp" | tail -1)
  body=$(echo "$resp" | sed '$d')
  if [[ "$code" -ge 400 ]]; then
    echo "Error ($code): $body" >&2
    return 1
  fi
  echo "$body"
}

_get() {
  local resp
  resp=$(curl -s -w '\n%{http_code}' "$BRIDGE$1")
  local code body
  code=$(echo "$resp" | tail -1)
  body=$(echo "$resp" | sed '$d')
  if [[ "$code" -ge 400 ]]; then
    echo "Error ($code): $body" >&2
    return 1
  fi
  echo "$body"
}

_del() {
  local resp
  resp=$(curl -s -w '\n%{http_code}' -X DELETE "$BRIDGE$1" -H 'Content-Type: application/json' -d "$2")
  local code body
  code=$(echo "$resp" | tail -1)
  body=$(echo "$resp" | sed '$d')
  if [[ "$code" -ge 400 ]]; then
    echo "Error ($code): $body" >&2
    return 1
  fi
  echo "$body"
}

_patch() {
  local resp
  resp=$(curl -s -w '\n%{http_code}' -X PATCH "$BRIDGE$1" -H 'Content-Type: application/json' -d "$2")
  local code body
  code=$(echo "$resp" | tail -1)
  body=$(echo "$resp" | sed '$d')
  if [[ "$code" -ge 400 ]]; then
    echo "Error ($code): $body" >&2
    return 1
  fi
  echo "$body"
}

case "${1:-help}" in

  # ── Create shapes ──────────────────────────────────────────────
  note)
    # canvas note "text" [x] [y] [color]
    _post "/api/note" "$(jq -n \
      --arg t "${2:?text required}" \
      --argjson x "${3:-200}" \
      --argjson y "${4:-200}" \
      --arg c "${5:-yellow}" \
      '{text:$t, x:$x, y:$y, color:$c}')"
    ;;

  box)
    # canvas box "text" [x] [y] [w] [h] [color]
    _post "/api/box" "$(jq -n \
      --arg t "${2:-}" \
      --argjson x "${3:-200}" \
      --argjson y "${4:-200}" \
      --argjson w "${5:-200}" \
      --argjson h "${6:-100}" \
      --arg c "${7:-black}" \
      '{text:$t, x:$x, y:$y, w:$w, h:$h, color:$c}')"
    ;;

  text)
    # canvas text "text" [x] [y]
    _post "/api/text" "$(jq -n \
      --arg t "${2:?text required}" \
      --argjson x "${3:-200}" \
      --argjson y "${4:-200}" \
      '{text:$t, x:$x, y:$y}')"
    ;;

  arrow)
    # canvas arrow <from-id> <to-id> [label]
    _post "/api/arrow" "$(jq -n \
      --arg f "${2:?from-id required}" \
      --arg t "${3:?to-id required}" \
      --arg l "${4:-}" \
      '{from:$f, to:$t, text:$l}')"
    ;;

  # ── Update / Delete ────────────────────────────────────────────
  update)
    # canvas update <shape-id> '{"props":{"text":"new text","color":"red"}}'
    _patch "/api/shapes" "$(jq -n --arg id "${2:?shape-id required}" --argjson c "${3:?changes JSON required}" '{shapes:[{id:$id} + $c]}')"
    ;;

  delete)
    # canvas delete <id> [id2] [id3] ...
    shift
    [[ $# -eq 0 ]] && { echo "Usage: canvas delete <id> [id...]" >&2; exit 1; }
    _del "/api/shapes" "$(printf '%s\n' "$@" | jq -R . | jq -s '{ids:.}')"
    ;;

  # ── Read ───────────────────────────────────────────────────────
  shapes)
    # canvas shapes — list all shapes
    _get "/api/shapes"
    ;;

  snapshot)
    _get "/api/snapshot"
    ;;

  # ── Canvas operations ──────────────────────────────────────────
  clear)
    _post "/api/clear" '{}'
    ;;

  zoom)
    _post "/api/zoom-to-fit" '{}'
    ;;

  health)
    _get "/api/health"
    ;;

  # ── Batch ──────────────────────────────────────────────────────
  batch)
    # canvas batch '<json array of operations>'
    _post "/api/batch" "$(jq -n --argjson ops "${2:?operations JSON required}" '{operations: $ops}')"
    ;;

  # ── Raw ────────────────────────────────────────────────────────
  post)
    _post "${2:?path required}" "${3:?body required}"
    ;;

  get)
    _get "${2:?path required}"
    ;;

  # ── Help ───────────────────────────────────────────────────────
  help|--help|-h)
    cat <<'USAGE'
canvas — TLDraw bridge CLI

Create:
  canvas note "text" [x] [y] [color]          Add a sticky note
  canvas box "text" [x] [y] [w] [h] [color]   Add a labeled rectangle
  canvas text "text" [x] [y]                   Add text
  canvas arrow <from-id> <to-id> [label]       Connect two shapes

Update / Delete:
  canvas update <id> '{"props":{...}}'         Update a shape
  canvas delete <id> [id2] [id3...]            Delete shape(s)

Read:
  canvas shapes                                 List all shapes (JSON)
  canvas snapshot                               Full canvas snapshot

Canvas:
  canvas clear                                  Clear all shapes
  canvas zoom                                   Zoom to fit content
  canvas health                                 Check bridge status

Batch:
  canvas batch '[{"type":"createShapes","payload":{...}},...]'

Raw:
  canvas post /api/path '{"json":"body"}'
  canvas get /api/path

Colors: black, grey, light-violet, violet, blue, light-blue, yellow,
        orange, green, light-green, light-red, red, white

Environment:
  CANVAS_BRIDGE_URL  Bridge server URL (default: http://localhost:3100)
USAGE
    ;;

  *)
    echo "Unknown command: $1 (try 'canvas help')" >&2
    exit 1
    ;;
esac
